<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainTracking"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Header Section Background -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#0D1B3E"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:layout_marginTop="32dp"
        app:contentInsetStart="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:padding="10dp"
                android:src="@drawable/ic_menu"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Driver Navigation"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp">

                    <ImageView
                        android:id="@+id/ivNotification"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/notification"
                        app:tint="@color/white" />

                    <TextView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_alignTop="@id/ivNotification"
                        android:layout_alignEnd="@id/ivNotification"
                        android:layout_marginTop="-4dp"
                        android:layout_marginEnd="-4dp"
                        android:background="@drawable/bg_badge"
                        android:backgroundTint="#EF4444"
                        android:gravity="center"
                        android:text="@string/notification_count"
                        android:textColor="@color/white"
                        android:textSize="8sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivProfileTop"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@drawable/ic_driver"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    app:strokeColor="@color/status_green"
                    app:strokeWidth="1.5dp" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- Info blocks strip -->
    <LinearLayout
        android:id="@+id/infoBlocks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="#1AFFFFFF"
        android:paddingVertical="12dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <!-- Bus Block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingStart="12dp">
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/blue_bus" app:tint="@color/accent_blue" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bus ID" android:textColor="#B3FFFFFF" android:textSize="10sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BUS-1023" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Route Block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical">
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/route" app:tint="@color/status_green" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Route" android:textColor="#B3FFFFFF" android:textSize="10sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Route 7A" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Date Block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical">
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/date" app:tint="#A855F7" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Date" android:textColor="#B3FFFFFF" android:textSize="10sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="24 May 2025" android:textColor="@color/white" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Trip Info Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/routeCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/infoBlocks">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/dotStart"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/greencircle"
                    android:backgroundTint="@color/status_green"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/lineVertical"
                    android:layout_width="2dp"
                    android:layout_height="35dp"
                    android:layout_marginTop="4dp"
                    android:background="#E2E8F0"
                    app:layout_constraintEnd_toEndOf="@id/dotStart"
                    app:layout_constraintStart_toStartOf="@id/dotStart"
                    app:layout_constraintTop_toBottomOf="@id/dotStart" />

                <ImageView
                    android:id="@+id/dotEnd"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginTop="45dp"
                    android:src="@drawable/redcircle"
                    android:backgroundTint="#EF4444"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/dotStart" />

                <TextView
                    android:id="@+id/tvStartLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Start Location"
                    android:textColor="@color/status_green"
                    android:textSize="11sp"
                    app:layout_constraintStart_toEndOf="@id/dotStart"
                    app:layout_constraintTop_toTopOf="@id/dotStart" />

                <TextView
                    android:id="@+id/tvStartValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Main Terminal, City Center"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="@id/tvStartLabel"
                    app:layout_constraintTop_toBottomOf="@id/tvStartLabel" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="09:00 AM"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvStartLabel" />

                <TextView
                    android:id="@+id/tvDestLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Destination"
                    android:textColor="#EF4444"
                    android:textSize="11sp"
                    app:layout_constraintStart_toStartOf="@id/tvStartLabel"
                    app:layout_constraintTop_toTopOf="@id/dotEnd" />

                <TextView
                    android:id="@+id/tvDestValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Green Town, Sector B"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="@id/tvDestLabel"
                    app:layout_constraintTop_toBottomOf="@id/tvDestLabel" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="09:45 AM"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvDestLabel" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#F1F5F9" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_vertical">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/map" app:tint="@color/accent_blue" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Stops" android:textColor="@color/text_secondary" android:textSize="10sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12" android:textColor="@color/text_primary" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_vertical">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@drawable/road" app:tint="@color/status_green" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Est. Distance" android:textColor="@color/text_secondary" android:textSize="10sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="18.6 km" android:textColor="@color/text_primary" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_vertical">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_recent_history" app:tint="#F59E0B" />
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Est. Duration" android:textColor="@color/text_secondary" android:textSize="10sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="45 min" android:textColor="@color/text_primary" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Map View -->
    <FrameLayout
        android:id="@+id/mapPlaceholder"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/btnStartNav"
        app:layout_constraintTop_toBottomOf="@id/routeCard">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.2"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_mapmode" />

        <!-- Map Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_margin="16dp"
            android:orientation="vertical">
            <com.google.android.material.card.MaterialCardView android:layout_width="44dp" android:layout_height="44dp" app:cardCornerRadius="22dp" app:cardElevation="2dp"><ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:src="@drawable/mylocation" /></com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:layout_width="44dp" android:layout_height="88dp" android:layout_marginTop="8dp" app:cardCornerRadius="8dp" app:cardElevation="2dp"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical"><ImageView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:padding="10dp" android:src="@drawable/add" /><View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F1F5F9" /><ImageView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:padding="10dp" android:src="@drawable/delete" /></LinearLayout></com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:layout_marginBottom="40dp"
            android:src="@drawable/buslocation"
            app:tint="@color/status_green" />

        <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/destination" android:layout_gravity="center" android:layout_marginStart="80dp" app:tint="#EF4444"/>

    </FrameLayout>

    <!-- Start Navigation Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartNav"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_margin="16dp"
        android:backgroundTint="#10B981"
        android:text="START NAVIGATION"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="14dp"
        app:icon="@android:drawable/ic_media_play"
        app:iconGravity="textStart"
        app:layout_constraintBottom_toTopOf="@id/bottomNavCard" />

    <!-- Bottom Navigation -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="16dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:background="@color/white"
            app:itemIconTint="@color/nav_item_color"
            app:itemTextColor="@color/nav_item_color"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/d_profile_details" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
